{
  "buildCommand": "npm install && node scripts/generate-sitemap.js && node scripts/ping-sitemap.js",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/upload-file.js": { "maxDuration": 30 }
  },
  "redirects": [
    { "source": "/index.html",              "destination": "/",                    "statusCode": 301 },
    { "source": "/about.html",              "destination": "/about",               "statusCode": 301 },
    { "source": "/accessibility.html",      "destination": "/accessibility",       "statusCode": 301 },
    { "source": "/commitment.html",         "destination": "/commitment",          "statusCode": 301 },
    { "source": "/contact.html",            "destination": "/contact",             "statusCode": 301 },
    { "source": "/contact-success.html",    "destination": "/contact-success",     "statusCode": 301 },
    { "source": "/employee-benefits.html",  "destination": "/employee-benefits",   "statusCode": 301 },
    { "source": "/property-liability.html", "destination": "/property-liability",  "statusCode": 301 },
    { "source": "/renewal-checklist.html",  "destination": "/renewal-checklist",   "statusCode": 301 },
    { "source": "/renewal-report-card.html","destination": "/renewal-report-card", "statusCode": 301 },
    { "source": "/solutions.html",          "destination": "/solutions",           "statusCode": 301 },
    { "source": "/what-we-find.html",       "destination": "/what-we-find",        "statusCode": 301 },
    { "source": "/why.html",                "destination": "/why",                 "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
